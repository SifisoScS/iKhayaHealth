{
  "name": "ikhaya-health-backend",
  "version": "1.0.0",
  "description": "iKhaya Health Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "node scripts/run-migrations.js",
    "migrate:rollback": "node scripts/rollback-migration.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint api/ db/config.js server.js",
    "lint:fix": "eslint api/ db/config.js server.js --fix",
    "format": "prettier --write api/ db/config.js server.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.2.5",
    "supertest": "^7.1.3"
  },
  "overrides": {
    "tar": "^6.2.1"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/../tests"
    ],
    "testMatch": [
      "**/*.test.js"
    ],
    "modulePaths": [
      "<rootDir>/node_modules"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 75,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "collectCoverageFrom": [
      "api/**/*.js",
      "db/config.js",
      "server.js",
      "../security/**/*.js",
      "../sync/**/*.js",
      "!db/migrations/**"
    ]
  }
}
