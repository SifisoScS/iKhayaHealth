# =============================================================================
# iKhaya Health — root .env.example
# Copy to .env and fill in values before running any service.
# Each service also has its own .env.example in its subdirectory.
# =============================================================================

# ---------------------------------------------------------------------------
# Backend (see backend/.env.example for full details)
# ---------------------------------------------------------------------------
PORT=3001
NODE_ENV=development
DATABASE_URL=postgresql://localhost:5432/ikhaya_health

# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-random-64-char-hex-string
JWT_EXPIRES_IN=8h

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-this-to-a-64-char-hex-string

# Comma-separated allowed CORS origins (empty = block all cross-origin)
ALLOWED_ORIGINS=

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Flutter mobile
# ---------------------------------------------------------------------------
# Base URL the app uses to reach the backend API
API_BASE_URL=http://10.0.2.2:3001/api

# Environment tag surfaced inside the app (development | staging | production)
FLUTTER_ENV=development

# ---------------------------------------------------------------------------
# Android release signing (CI/CD — used by android/app/build.gradle.kts)
# ---------------------------------------------------------------------------
# Path to the .keystore / .jks file
KEYSTORE_PATH=release.keystore
KEYSTORE_PASSWORD=change-this
KEY_ALIAS=ikhaya-release
KEY_PASSWORD=change-this

# ---------------------------------------------------------------------------
# Docker Compose overrides (optional)
# ---------------------------------------------------------------------------
POSTGRES_USER=ikhaya
POSTGRES_PASSWORD=change-this
POSTGRES_DB=ikhaya_health
